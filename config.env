# ================================
# إعدادات التعدين الآمن على Heroku
# ================================

# اسم تطبيق Heroku الخاص بك
APP_NAME="afdaa"

# ضع هنا عنوان محفظة Monero / XMR من زر Receive فقط
# لا تضع كلمات الاسترداد أو المفتاح الخاص
XMR_WALLET="86HoPo7YGXU66KN4L7EsMzDcNTWDpbNmd455TW18ozuoSe1JeW2pzUSUabLPEcCwG58E3jPHYLnQYB3F5ouZ7n1J4TaknW4"

# Pool
XMR_POOL="pool.supportxmr.com:3333"

# اسم العامل الذي سيظهر في الـ Pool
WORKER_NAME="afdaa1"

# إعدادات أمان الموارد
# لا ترفعها في Heroku إلا إذا تأكدت أن التطبيق مستقر
XMR_THREADS="1"
RESOURCE_PERCENT="25"
RANDOMX_MODE="light"

# تشغيل وإيقاف تلقائي لتقليل الاستهلاك المتوسط
DUTY_CYCLE="on"
DUTY_WORK_SECONDS="5"
DUTY_SLEEP_SECONDS="15"

# عند قتل XMRig بالكود -9/137، سيقلل الاستهلاك تلقائيًا
AUTO_BACKOFF="on"

# نسبة تبرع XMRig الرسمية. يمكن جعلها 1 كحد أدنى
DONATE_LEVEL="1"
